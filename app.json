{
  "expo": {
    "name": "FestFood Manager",
    "slug": "fest-food-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "festfoodmanagermobile",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.killuazoldycksorganization.festfoodmanager",
      "supportsTablet": true
    },
    "android": {
      "package": "com.killuazoldycksorganization.festfoodmanager",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FestFood Manager to access your camera to scan QR tickets."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e866717-1d36-4b2d-8378-b4ca787b5a0b"
      }
    }
  }
}
